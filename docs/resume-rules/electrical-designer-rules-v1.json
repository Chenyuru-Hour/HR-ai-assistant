{
  "version": "v1",
  "position": "电气设计师",
  "department": "技术部",
  "hard_filters": {
    "education_min": "专科及以上",
    "education_major": ["电气设计", "电气技术", "工业自动化", "机电一体化"],
    "industry_experience_years": 2,
    "same_position_experience_years": 2,
    "managed_staff_count": 0,
    "software_basic_capability_required": true,
    "technical_coverage_required": [
      "电气原理与配线",
      "自动化电气编程",
      "电驱/液驱/气驱应用"
    ]
  },
  "soft_filters": {
    "electrical_design_skill": {
      "weight": 0.30,
      "min_score": 3,
      "description": "电气原理图、接线图设计，元器件选型，BOM编制"
    },
    "automation_programming_skill": {
      "weight": 0.25,
      "min_score": 3,
      "description": "PLC编程、控制程序编写与调试"
    },
    "drive_system_application": {
      "weight": 0.15,
      "min_score": 3,
      "description": "电驱/液驱/气驱的应用能力"
    },
    "project_lifecycle_experience": {
      "weight": 0.15,
      "min_score": 3,
      "description": "参与项目从对接、设计、加工支持、现场调试到验收的全流程经验"
    },
    "communication_collaboration_skill": {
      "weight": 0.10,
      "min_score": 3,
      "description": "与客户、加工厂、现场人员等的沟通协作能力"
    },
    "benchmark_company_background": {
      "weight": 0.05,
      "min_score": 1,
      "description": "对标单位工作经验（优先加分项）"
    }
  },
  "scoring_rules": {
    "score_calculation": "sum(soft_score_i * weight_i) * 20",
    "score_threshold": 75,
    "reject_on_hard_fail": true,
    "gray_review_trigger": {
      "benchmark_score": 4,
      "total_score_range": [70, 74]
    }
  },
  "keywords_extraction": {
    "job_duties": [
      "电气方案设计及深化",
      "电气加工/施工图纸设计",
      "控制程序编写",
      "材料清单(BOM)编制",
      "加工厂技术支持",
      "现场安装调试人员支持",
      "技术资料存档"
    ],
    "required_software": [
      "主流工业设计软件（如EPLAN/AutoCAD Electrical）",
      "PLC编程软件（如TIA Portal/Step7/GX Works）",
      "办公软件（Office/WPS）"
    ]
  }
}